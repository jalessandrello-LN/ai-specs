{
    "compileOnSave": false,
    "compilerOptions": {
        "esModuleInterop": true,
        "rootDir": ".",
        "incremental": true,
        "sourceMap": true,
        "forceConsistentCasingInFileNames": true,
        "composite": true,
        "allowJs": true,
        "declaration": true,
        "moduleResolution": "node",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "importHelpers": true,
        "target": "ES2020",
        "module": "CommonJS",
        "lib": ["es2020", "dom"],
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "outDir": "dist",
        "strict": true,
        "paths": {
            "@la-nacion.core.template.monoreponx/my-plugin": [
                "tools/my-plugin/src/index.ts"
            ],
            "@ln/generators": ["tools/ln-generators/src/index.ts"]
        }
    },
    "exclude": [
        "node_modules",
        "tmp",
        "tools/ln-generators/src/generators/add-listener/files/cdk"
    ]
}
