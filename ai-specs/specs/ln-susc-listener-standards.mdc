## CQRS Implementation

### Event Processor (Handler)

```csharp
using System;
using System.Threading;
using System.Threading.Tasks;
using MediatR;
using Microsoft.Extensions.Logging;
using LaNacion.Core.Infraestructure.Domain.Entities;
using LaNacion.Core.Infraestructure.Data.Relational;

namespace LaNacion.Suscripciones.SqsRdr.Application
{
    public class SuscripcionCreadaProcessor : IRequestHandler<SuscripcionCreada, ProcessResult>
    {
        private readonly ILogger<SuscripcionCreadaProcessor> _logger;
        private readonly IUnitOfWork _uow;
        private readonly ISuscripcionRepository _repository;

        public SuscripcionCreadaProcessor(
            ILogger<SuscripcionCreadaProcessor> logger,
            IUnitOfWork uow,
            ISuscripcionRepository repository)
        {
            _logger = logger;
            _uow = uow;
            _repository = repository;
        }

        public async Task<ProcessResult> Handle(SuscripcionCreada @event, CancellationToken ct)
        {
            try
            {
                _logger.LogInformation(">>> Processing SuscripcionCreada: Id={Id}", @event.Id);

                // Validation
                if (@event.Id == Guid.Empty)
                {
                    _logger.LogWarning("Invalid event: Id is empty");
                    return new ProcessResult 
                    { 
                        Succed = false, 
                        ErrorDescription = "ID is required" 
                    };
                }

                // Nota: La verificación de idempotencia se realiza automáticamente 
                // en la clase base SqsQueueConsumerService<T>. 
                // Si el flujo entra aquí, garantizado que es la primera vez.

                // Check if entity already exists
                var existing = await _repository.GetByIdAsync(@event.Id);
                if (existing != null)
                {
                    _logger.LogInformation("Entity already exists, skipping");
                    return new ProcessResult { Succed = true, ErrorDescription = "" };
                }

                // Process with transaction
                using (_uow.BeginTransaction())
                {
                    var suscripcion = new Suscripcion
                    {
                        Id = @event.Id,
                        ClienteId = @event.ClienteId,
                        PlanId = @event.PlanId,
                        Estado = EstadoSuscripcion.Activa,
                        LastModifiedBy = "SQS-Worker",
                        LastModifyDate = DateTime.UtcNow
                    };

                    await _repository.AddAsync(suscripcion);
                    
                    _uow.Commit();
                }

                _logger.LogInformation("<<< SuscripcionCreada processed successfully");
                return new ProcessResult { Succed = true, ErrorDescription = "" };
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error processing SuscripcionCreada");
                return new ProcessResult 
                { 
                    Succed = false, 
                    ErrorDescription = ex.Message 
                };
            }
        }
    }
}
```

### ProcessResult Pattern

All event handlers return `ProcessResult`:

```csharp
public class ProcessResult
{
    public bool Succed { get; set; }
    public string ErrorDescription { get; set; }
}

// Success
return new ProcessResult { Succed = true, ErrorDescription = "" };

// Failure
return new ProcessResult { Succed = false, ErrorDescription = "Validation failed" };
```

## SQS Consumer Patterns

### Hosted Service Configuration

```csharp
// ConfigureServicesExtensions.cs
public static class ConfigureServicesExtensions
{
    public static IServiceCollection AddWorkers(this IServiceCollection services)
    {
        // Register SQS consumer for SuscripcionCreada event
        services.AddSingleton(new SqsQueueNameService<SuscripcionCreada>(
            "suscripciones-prod-sqs-ventas-alta"
        ));
        
        services.AddHostedService<SqsQueueConsumerService<SuscripcionCreada>>();
        
        return services;
    }
}
```

### Queue Configuration

```json
// appsettings.json
{
  "SQS": {
    "Queues": {
      "suscripciones-prod-sqs-ventas-alta": "https://sqs.us-east-1.amazonaws.com/123456789012/suscripciones-prod-sqs-ventas-alta",
      "suscripciones-prod-sqs-cobranzas-resultado": "https://sqs.us-east-1.amazonaws.com/123456789012/suscripciones-prod-sqs-cobranzas-resultado"
    }
  }
}
```

### Message Polling & Deletion

The `SqsQueueConsumerService<T>` handles:
- Long polling from SQS
- Message deserialization to event type
- Invoking MediatR handler
- Deleting message on success
- Moving to DLQ on repeated failures

## Idempotency Implementation

La librería base `LaNacion.Core.Infraestructure.Events.Suscriber` ya implementa la idempotencia de forma transparente usando `IReceivedMessageRepository`.
- No es necesario manejar una tabla `MensajesRecibidos` dentro de cada dominio.
- No es necesario inyectar `IMensajesRecibidosRepository` en los processors o handlers.
- El handler sólo se invocará si el mensaje no ha sido procesado exitosamente con anterioridad.

## Database Patterns

### Dapper with Unit of Work

```csharp
public class SuscripcionRepository : BaseRepository<Suscripcion, Guid>, ISuscripcionRepository
{
    public SuscripcionRepository(IContext context) : base(context, "Suscripciones") { }
    
    public async Task<Suscripcion> GetByIdAsync(Guid id)
    {
        const string sql = "SELECT * FROM Suscripciones WHERE Id = @Id";
        return await _context.Connection.QueryFirstOrDefaultAsync<Suscripcion>(
            sql,
            new { Id = id },
            Transaction
        );
    }
}
```

### Transaction Management

```csharp
// Always use Unit of Work for atomic operations
using (_uow.BeginTransaction())
{
    await _repository.AddAsync(entity);
    _uow.Commit();
}
```

### Dependency Injection

```csharp
// Program.cs
services.AddScoped<ISuscripcionRepository, SuscripcionRepository>();
services.AddScoped<IUnitOfWork, UnitOfWork>();
```

## Testing Standards

### Unit Testing Event Processors

```csharp
public class SuscripcionCreadaProcessorTests
{
    private readonly Mock<ISuscripcionRepository> _repositoryMock;
    private readonly Mock<IMensajesRecibidosRepository> _mensajesMock;
    private readonly Mock<IUnitOfWork> _uowMock;
    private readonly Mock<ILogger<SuscripcionCreadaProcessor>> _loggerMock;
    private readonly SuscripcionCreadaProcessor _processor;
    
    public SuscripcionCreadaProcessorTests()
    {
        _repositoryMock = new Mock<ISuscripcionRepository>();
        _uowMock = new Mock<IUnitOfWork>();
        _loggerMock = new Mock<ILogger<SuscripcionCreadaProcessor>>();
        
        _processor = new SuscripcionCreadaProcessor(
            _loggerMock.Object,
            _uowMock.Object,
            _repositoryMock.Object
        );
    }
    
    [Fact]
    public async Task Handle_NewEvent_ProcessesSuccessfully()
    {
        // Arrange
        var @event = new SuscripcionCreada
        {
            Id = Guid.NewGuid(),
            ClienteId = "CLI-123",
            PlanId = "PLAN-456"
        };
        
        _repositoryMock.Setup(x => x.GetByIdAsync(@event.Id))
            .ReturnsAsync((Suscripcion)null);
        
        // Act
        var result = await _processor.Handle(@event, CancellationToken.None);
        
        // Assert
        result.Succed.Should().BeTrue();
        _repositoryMock.Verify(x => x.AddAsync(It.IsAny<Suscripcion>(), It.IsAny<CancellationToken>()), Times.Once);
        _uowMock.Verify(x => x.Commit(), Times.Once);
    }
    
    [Fact]
    public async Task Handle_EntityAlreadyExists_SkipsProcessing()
    {
        // Arrange
        var @event = new SuscripcionCreada { Id = Guid.NewGuid() };
        
        _repositoryMock.Setup(x => x.GetByIdAsync(@event.Id))
            .ReturnsAsync(new Suscripcion());
        
        // Act
        var result = await _processor.Handle(@event, CancellationToken.None);
        
        // Assert
        result.Succed.Should().BeTrue();
        _repositoryMock.Verify(x => x.AddAsync(It.IsAny<Suscripcion>(), It.IsAny<CancellationToken>()), Times.Never);
    }
}
```

